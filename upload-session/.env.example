PORT=3008
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=upload_session_db
DB_USER=postgres
DB_PASSWORD=postgres

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=upload-session
KAFKA_GROUP_ID=upload-session-group

# Service URLs (for REST integration)
FILE_REGISTRY_URL=http://localhost:3007
CHUNK_CATALOG_URL=http://localhost:3009

# Session Config
SESSION_TTL_MINUTES=60
