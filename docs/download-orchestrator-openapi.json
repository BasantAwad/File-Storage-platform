{
    "openapi": "3.0.0",
    "info": {
        "title": "Download Orchestrator API",
        "description": "API for managing file downloads with orchestration",
        "version": "1.0.0",
        "contact": {
            "name": "CSE474 Team",
            "email": "team@cse474.local"
        }
    },
    "servers": [
        {
            "url": "http://localhost:3001",
            "description": "Development server"
        },
        {
            "url": "https://api.cse474.local/downloads",
            "description": "Production server"
        }
    ],
    "tags": [
        {
            "name": "Health",
            "description": "Service health check endpoints"
        },
        {
            "name": "Downloads",
            "description": "Download management endpoints"
        },
        {
            "name": "Observability",
            "description": "Observability endpoints"
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "Service is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "service": {
                                            "type": "string"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "tags": [
                    "Observability"
                ],
                "summary": "Prometheus metrics",
                "responses": {
                    "200": {
                        "description": "Metrics in Prometheus format",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Error": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "error": {
                        "type": "string"
                    }
                }
            },
            "DownloadPlan": {
                "type": "object",
                "properties": {
                    "fileId": {
                        "type": "string"
                    },
                    "userId": {
                        "type": "string"
                    },
                    "chunks": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "index": {
                                    "type": "integer"
                                },
                                "size": {
                                    "type": "integer"
                                },
                                "checksum": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}