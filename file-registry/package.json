{
  "name": "file-registry",
  "version": "1.0.0",
  "description": "File Registry microservice — manages file metadata lifecycle",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "migrate": "node src/db/migrate.js",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "kafkajs": "^2.2.4",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-async-errors": "^3.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
