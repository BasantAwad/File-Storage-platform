{
  "name": "api-keys-service",
  "version": "1.0.0",
  "description": "Nexus Distributed File Storage - API Keys Service",
  "main": "src/app.js",
  "scripts": {
    "start": "pm2 start ecosystem.config.js --no-daemon",
    "dev": "node src/app.js",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
