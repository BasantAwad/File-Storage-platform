  },
  "dependencies": {
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "kafkajs": "^2.2.4",
    "uuid": "^9.0.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "pm2": "^5.3.0"
  }
}
